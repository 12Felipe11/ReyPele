# Copiar a Avance/supabase/.env (o a la raiz del repo) y rellenar.
# NUNCA commitear el archivo real (.env esta en .gitignore).

# URL del proyecto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co

# API key. En desarrollo se puede usar "anon" con RLS abierto,
# pero para escritura desde un proceso Java lo mas comodo es
# "service_role" (Settings > API > service_role secret).
# Ojo: service_role salta RLS, manejarla con cuidado.
SUPABASE_KEY=eyJhbGciOi...
